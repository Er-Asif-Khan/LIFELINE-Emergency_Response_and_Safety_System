<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_home_background"
    android:fillViewport="true">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- GPS Status -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_signal"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GPS ACTIVE"
            android:textStyle="bold"
            android:textColor="@color/light_home_network"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <!-- Ready Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ready_status_bg"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/green_dot"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="@color/light_btnReady"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Settings Icon -->
        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/icon_bg"
            android:padding="8dp"
            />
    </LinearLayout>

    <!-- SOS Button with Glow Effect -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_above="@id/shakeToggleCard"
        android:gravity="center">

        <!-- Shadow GlowLayer 1 -->
        <View
            android:layout_width="330dp"
            android:layout_height="330dp"
            android:alpha="0.5"
            android:layout_centerInParent="true"
            android:background="@drawable/glow_shadow"/>

        <!-- Outer Glow Layer 1 -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:alpha="0.5"
            android:layout_centerInParent="true"
            android:background="@drawable/glow_outer"/>

        <!-- Middle Glow Layer 2 -->
        <View
            android:layout_width="270dp"
            android:layout_height="270dp"
            android:layout_centerInParent="true"
            android:alpha="0.5"
            android:background="@drawable/glow_middle"/>

        <!-- SOS Button -->
        <RelativeLayout
            android:id="@+id/sosButton"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_centerInParent="true"
            android:background="@drawable/sos_button_bg"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOS"
                    android:textColor="@color/white"
                    android:textSize="72sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TAP TO SIGNAL"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>

    <!-- Shake to Trigger Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/shakeToggleCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomSection"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        android:layout_marginTop="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start">

                <View
                    android:id="@+id/red_circle"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/icon_bg_light_red"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>


                <ImageView
                    android:id="@+id/shakeIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_shake"
                    android:layout_centerVertical="true"
                    app:layout_constraintStart_toStartOf="@id/red_circle"
                    app:layout_constraintTop_toTopOf="@id/red_circle"
                    app:layout_constraintEnd_toEndOf="@id/red_circle"
                    app:layout_constraintBottom_toBottomOf="@id/red_circle"/>
            </androidx.constraintlayout.widget.ConstraintLayout>



            <LinearLayout
                android:layout_width="190dp"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/shakeIcon"
                android:layout_toStartOf="@id/shakeToggle"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shake to Trigger"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sensitivity: Medium"
                    android:textColor="@color/light_home_text"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/shakeToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:checked="false"
                android:theme="@style/SwitchTheme"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Section -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Contacts and History Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Contacts Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/contactsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start">

                        <View
                            android:id="@+id/circle"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/icon_bg_light_blue"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>


                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_contacts"
                            app:layout_constraintStart_toStartOf="@id/circle"
                            app:layout_constraintTop_toTopOf="@id/circle"
                            app:layout_constraintEnd_toEndOf="@id/circle"
                            app:layout_constraintBottom_toBottomOf="@id/circle"
                            />

                    </androidx.constraintlayout.widget.ConstraintLayout>



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contacts"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="12dp"
                        android:layout_marginStart="4dp"
                        android:textStyle="bold"
                        android:layout_gravity="start"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Manage trusted circle"
                        android:textColor="@color/light_home_text"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_gravity="start"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- History Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/historyCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start">

                        <View
                            android:id="@+id/orange_circle"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/icon_bg_light_orange"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>


                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_history"
                            app:layout_constraintStart_toStartOf="@id/orange_circle"
                            app:layout_constraintTop_toTopOf="@id/orange_circle"
                            app:layout_constraintEnd_toEndOf="@id/orange_circle"
                            app:layout_constraintBottom_toBottomOf="@id/orange_circle"
                            />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="History"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="12dp"
                        android:layout_marginStart="4dp"
                        android:textStyle="bold"
                        android:layout_gravity="start"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Past alerts &amp; logs"
                        android:textColor="@color/light_home_text"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="4dp"
                        android:layout_gravity="start"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Safety Guide Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/safetyGuideCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start">

                    <View
                        android:id="@+id/safety_circle"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/icon_bg_light_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>


                    <ImageView
                        android:id="@+id/safetyIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_safety"
                        app:layout_constraintStart_toStartOf="@id/safety_circle"
                        app:layout_constraintTop_toTopOf="@id/safety_circle"
                        app:layout_constraintEnd_toEndOf="@id/safety_circle"
                        app:layout_constraintBottom_toBottomOf="@id/safety_circle"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <LinearLayout
                    android:layout_width="208dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="23dp"
                    android:layout_marginEnd="-2dp"
                    android:layout_marginTop="10dp"
                    android:layout_toStartOf="@id/arrowIcon"
                    android:layout_toEndOf="@id/safetyIcon"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Safety Guide"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Emergency procedures"
                        android:textColor="@color/light_home_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/arrowIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_right"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</RelativeLayout>