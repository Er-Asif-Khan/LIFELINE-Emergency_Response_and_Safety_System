<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="12dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/light_home_network"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="50dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <View
                android:id="@+id/purple_circle"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/icon_bg_light_purple"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
            <!-- Profile Image -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImage1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/profile"
                app:layout_constraintStart_toStartOf="@id/purple_circle"
                app:layout_constraintTop_toTopOf="@id/purple_circle"
                app:layout_constraintEnd_toEndOf="@id/purple_circle"
                app:layout_constraintBottom_toBottomOf="@id/purple_circle"
                android:layout_centerVertical="true"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <LinearLayout
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="80dp"
            android:layout_toStartOf="@id/actionButtons1"
            android:layout_toEndOf="@id/profileImage1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/black" />
            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="14sp"
                android:textColor="@color/light_home_text"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/actionButtons1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/icon_bg_light_red"
                android:contentDescription="Delete contact"
                app:tint="@color/alert_red"
                android:layout_marginEnd="8dp"/>
<!--            <ImageView-->
<!--                android:id="@+id/alertButton1"-->
<!--                android:layout_width="48dp"-->
<!--                android:layout_height="48dp"-->
<!--                android:padding="8dp"-->
<!--                android:src="@drawable/ic_delete"-->
<!--                android:background="@drawable/icon_button_bg"-->
<!--                app:tint="@color/black"-->
<!--            android:contentDescription="Delete contact"-->
<!--                android:layout_marginEnd="8dp"/>-->
        </LinearLayout>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>