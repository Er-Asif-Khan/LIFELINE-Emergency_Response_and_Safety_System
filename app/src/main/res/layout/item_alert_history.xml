<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_margin="5dp"
    app:cardCornerRadius="40dp"
    app:cardElevation="0dp"
    app:strokeWidth="3dp"
    app:strokeColor="@color/black"
    android:layout_marginBottom="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/sosIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_bell"
            android:background="@drawable/icon_bg_rec_red"
            android:padding="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/sosIcon"
            android:layout_toStartOf="@id/activeStatus"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOS Alert Sent"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/light_home_text"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/alert_red"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/alert_red"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvDeliveryStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • Delivered"
                    android:textColor="@color/alert_red"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/activeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Active"
            android:textColor="@color/alert_red"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/active_badge_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

        <View
            android:id="@+id/verticalLine"
            android:layout_width="2dp"
            android:layout_height="240dp"
            android:layout_marginTop="48dp"
            android:background="#E5E7EB"
            android:layout_marginStart="24dp"/>

        <LinearLayout
            android:id="@+id/locationSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingRight="16dp"
            android:paddingBottom="16dp"
            android:layout_marginTop="100dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/locationIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_location"
                    android:background="@drawable/icon_bg_light_gray"
                    android:padding="12dp"
                    app:tint="#6B7280"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/locationIcon"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvLocationTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Location Shared"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvLocationSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sent to Emergency Contacts"
                        android:textColor="@color/light_home_text"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </RelativeLayout>

            <!-- Map Preview (shown when successful) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/mapPreview"
                android:layout_width="wrap_content"
                android:layout_height="120dp"
                android:src="@drawable/map_preview_img"
                android:scaleType="centerCrop"
                android:layout_marginTop="12dp"
                android:layout_marginStart="56dp"
                app:shapeAppearanceOverlay="@style/RoundedCorner32"
                app:strokeColor="@color/light_home_text"
                app:strokeWidth="2dp"/>

            <!-- Error Card (shown when failed) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/errorCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginStart="56dp"
                app:cardBackgroundColor="#FEE2E2"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_bell"
                        app:tint="#DC2626"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvErrorMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No emergency contacts found"
                        android:textColor="#DC2626"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="6dp"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>