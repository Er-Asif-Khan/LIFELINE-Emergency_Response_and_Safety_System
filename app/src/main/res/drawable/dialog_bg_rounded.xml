<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#80000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Light catcher overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#26FFFFFF" /> <!-- Very faint white tint -->
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" /> <!-- The "glass" edge -->
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>